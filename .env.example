# Local development settings only. Do not put real production secrets in this template.

# Optional. When set, backend secret loading uses Azure Key Vault instead of local secret env vars.
KEY_VAULT_URL=

# PostgreSQL
# Use DATABASE_URL or the individual DATABASE_* values below. Azure PostgreSQL should keep SSL enabled.
DATABASE_URL=
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_NAME=mspharmony
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_SSL=true

# ConnectWise Manage
CONNECTWISE_ENDPOINT=https://api-na.myconnectwise.net
CONNECTWISE_COMPANY_ID=
CONNECTWISE_CLIENT_ID=
CONNECTWISE_PUBLIC_KEY=
CONNECTWISE_PRIVATE_KEY=

# Cove Data Protection
COVE_ENDPOINT=https://api.backup.management
COVE_PARTNER_NAME=
COVE_USERNAME=
COVE_PASSWORD=

# SentinelOne
SENTINELONE_ENDPOINT=https://usea1.sentinelone.net
SENTINELONE_API_TOKEN=

# Proofpoint Essentials
PROOFPOINT_ENDPOINT=https://api.proofpointessentials.com
PROOFPOINT_USERNAME=
PROOFPOINT_PASSWORD=

# Datto Backup / Kaseya Datto BCDR + SaaS Protection
DATTO_ENDPOINT=https://api.datto.com
DATTO_API_KEY=
DATTO_API_SECRET=

# Microsoft 365
MICROSOFT365_ENDPOINT=https://graph.microsoft.com
MICROSOFT365_CLIENT_ID=
MICROSOFT365_TENANT_ID=
MICROSOFT365_CLIENT_SECRET=

# AppRiver - OpenText
OPENTEXT_APPRIVER_ENDPOINT=https://unityapi.webrootcloudav.com
OPENTEXT_APPRIVER_CLIENT_ID=
OPENTEXT_APPRIVER_CLIENT_SECRET=
OPENTEXT_APPRIVER_REFRESH_TOKEN=
# Optional local-only fallback when KEY_VAULT_URL is blank. Production rotates this secret in Key Vault.
OPENTEXT_APPRIVER_REFRESH_TOKEN_CACHE_PATH=

# Microsoft Azure
AZURE_ENDPOINT=https://management.azure.com
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_SUBSCRIPTION_ID=
AZURE_CLIENT_SECRET=

# Static Web Apps tenant authentication
# The deployed staticwebapp.config.json pins sign-in to the production Entra tenant.
# Store these in Azure Static Web Apps app settings, not source control.
SWA_AUTH_AAD_CLIENT_ID=
SWA_AUTH_AAD_CLIENT_SECRET=

# Local development only. Leave blank/false in production so API role checks fail closed
# when PostgreSQL-backed app_users authorization is unavailable.
ALLOW_HEADER_ROLE_AUTH=false

# Pax8
PAX8_ENDPOINT=https://api.pax8.com
PAX8_CLIENT_ID=
PAX8_CLIENT_SECRET=
